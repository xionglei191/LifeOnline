<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="oval">
            <gradient
                android:angle="315"
                android:startColor="@color/bubble_main_start"
                android:centerColor="@color/bubble_main_center"
                android:endColor="@color/bubble_main_end" />
            <size
                android:width="56dp"
                android:height="56dp" />
        </shape>
    </item>
    <item
        android:left="4dp"
        android:top="5dp"
        android:right="4dp"
        android:bottom="5dp">
        <shape android:shape="oval">
            <gradient
                android:angle="270"
                android:startColor="#24FFFFFF"
                android:centerColor="#12FFFFFF"
                android:endColor="#08FFFFFF" />
        </shape>
    </item>
    <item
        android:left="8dp"
        android:top="6dp"
        android:right="20dp"
        android:bottom="25dp">
        <shape android:shape="oval">
            <gradient
                android:angle="315"
                android:startColor="#88FFFFFF"
                android:endColor="@android:color/transparent" />
        </shape>
    </item>
    <item
        android:left="18dp"
        android:top="27dp"
        android:right="18dp"
        android:bottom="14dp">
        <shape android:shape="oval">
            <gradient
                android:angle="90"
                android:startColor="#26FFFFFF"
                android:endColor="@android:color/transparent" />
        </shape>
    </item>
</layer-list>
