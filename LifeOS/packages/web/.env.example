# LifeOS Web proxy configuration
# Copy to .env.production on the machine that runs lifeos-web.service
#
# Default local mode on 246:
#   LIFEOS_API_HOST=localhost
#   LIFEOS_API_PORT=3000
#
# Optional tunnel / LAN override:
#   LIFEOS_API_HOST=lifeos-server.xionglei.online
#   LIFEOS_API_PORT=443

LIFEOS_API_HOST=localhost
LIFEOS_API_PORT=3000
