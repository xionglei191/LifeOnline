{
  "name": "@lifeos/server",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "db:init": "tsx scripts/init-db.ts",
    "index": "tsx -e \"import('./src/indexer/indexer.js').then(m => m.indexVault(process.env.VAULT_PATH || '../../mock-vault'))\"",
    "test": "node --import tsx --test --test-concurrency=1 test/**/*.test.ts",
    "smoke": "tsx scripts/smoke.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@aws-sdk/client-s3": "^3.1015.0",
    "better-sqlite3": "^12.8.0",
    "chokidar": "^5.0.0",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "gray-matter": "^4.0.3",
    "node-cron": "^4.2.1",
    "sql.js": "^1.14.1",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@lifeos/shared": "workspace:*",
    "@types/better-sqlite3": "^7.6.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.6",
    "@types/node-cron": "^3.0.11",
    "@types/ws": "^8.18.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
