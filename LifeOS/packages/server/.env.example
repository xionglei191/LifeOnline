# LifeOS Server Environment Variables
# Copy to .env.production and fill in real values

# Vault path (Obsidian markdown directory)
VAULT_PATH=/home/xionglei/Vault_OS

# Database path
DB_PATH=/home/xionglei/LifeOnline/LifeOS/packages/server/data/lifeos.db

# R2 Cold Storage (Cloudflare R2 / S3-compatible)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=vault2026

# CORS origin whitelist (comma-separated, default: * = allow all)
# Example: http://192.168.31.246:5173,http://localhost:5173
CORS_ORIGIN=*
